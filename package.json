{
  "name": "ephemeral-api",
  "version": "1.0.0",
  "description": "Backend for Ephemeral CTF Engine",
  "scripts": {
    "dev": "bun --watch src/server.ts",
    "dev:ui": "vite",
    "dev:full": "concurrently \"PORT=3010 npm run dev\" \"VITE_API_TARGET=http://localhost:3010 npm run dev:ui\"",
    "build": "vite build",
    "preview": "vite preview",
    "db:generate": "drizzle-kit generate:pg",
    "db:push": "drizzle-kit push:pg",
    "db:seed": "bun src/seed.ts"
  },
  "dependencies": {
    "@koa/cors": "^5.0.0",
    "@koa/router": "^12.0.1",
    "@neondatabase/serverless": "^0.9.0",
    "dotenv": "^17.4.2",
    "drizzle-orm": "^0.30.10",
    "koa": "^2.15.3",
    "koa-bodyparser": "^4.4.1",
    "koa-compress": "^5.2.1",
    "koa-helmet": "^9.0.0",
    "koa-json": "^2.0.2",
    "koa-logger": "^4.0.0",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@types/koa": "^2.15.0",
    "@types/koa-bodyparser": "^4.3.12",
    "@types/koa-compress": "^4.0.7",
    "@types/koa-json": "^2.0.24",
    "@types/koa-logger": "^3.1.5",
    "@types/koa__cors": "^5.0.0",
    "@types/koa__router": "^12.0.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.2",
    "concurrently": "^10.0.0",
    "drizzle-kit": "^0.20.17",
    "vite": "^8.0.14"
  }
}
